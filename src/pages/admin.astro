---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Consultamos los datos en el servidor
const { data: alumnos, error } = await supabase
  .from('alumnos')
  .select('*')
  .order('created_at', { ascending: false });

const carreras = [
  "Licenciatura Arquitectura",
  "Licenciatura en Derecho",
  "Licenciatura en Administración de Empresas Turísticas",
  "Contabilidad Pública",
  "Licenciatura en Sistemas Computacionales y Administrativos"
];
---

<Layout title="Admin - CELC 2026">
  <main class="min-h-screen bg-slate-50 p-4 md:p-8">
    <div class="max-w-7xl mx-auto">
      
      <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
          <h1 class="text-4xl font-black text-[#982a46]">Panel de Control</h1>
          <p class="text-slate-500 font-medium">Simposium CELC 2026</p>
        </div>
        <a href="/" class="px-6 py-2 bg-white border border-slate-200 rounded-full text-sm font-bold text-slate-600 hover:bg-slate-50 transition-all shadow-sm">
          ← Ir a la Landing
        </a>
      </header>

      <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="md:col-span-2 relative">
          <input 
            type="text" 
            id="nameSearch" 
            placeholder="Buscar por nombre del alumno..." 
            class="w-full pl-12 pr-4 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#982a46] outline-none shadow-sm transition-all"
          />
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
        </div>
        
        <select 
          id="careerFilter" 
          class="w-full px-4 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#982a46] outline-none shadow-sm text-slate-600 font-medium"
        >
          <option value="">Todas las Carreras</option>
          {carreras.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>

      <div class="bg-white rounded-[2.5rem] shadow-xl border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-slate-50/50 border-b border-slate-100">
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest">Estatus</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest">Alumno</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest text-center">Carrera</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest text-center">WhatsApp</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest text-right">Acción</th>
              </tr>
            </thead>
            <tbody id="adminTableBody" class="divide-y divide-slate-50">
              {alumnos?.map((alumno) => (
                <tr class={`alumno-row transition-all ${alumno.pagado ? 'bg-emerald-50/50' : 'hover:bg-slate-50'}`}>
                  <td class="px-6 py-4">
                    {alumno.pagado ? (
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-[10px] font-black">
                        PAGADO
                      </span>
                    ) : (
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-amber-100 text-amber-700 text-[10px] font-black">
                        PENDIENTE
                      </span>
                    )}
                  </td>

                  <td class="px-6 py-4">
                    <div class="font-bold text-slate-800">{alumno.nombre}</div>
                    <div class="text-xs text-slate-400">{alumno.email}</div>
                  </td>

                  <td class="px-6 py-4 text-center">
                    <span class="text-xs font-medium text-slate-500 bg-slate-100 px-2 py-1 rounded-lg">
                      {alumno.carrera}
                    </span>
                  </td>

                  <td class="px-6 py-4 text-center text-sm font-mono font-medium">
                    <a 
                      href={`https://wa.me/52${alumno.telefono.replace(/\D/g, '')}?text=Hola%20${encodeURIComponent(alumno.nombre)}!%20Te%20contacto%20del%20CELC%20sobre%20tu%20registro%20al%20Simposium...`} 
                      target="_blank"
                      class="text-green-600 hover:text-green-700 hover:underline transition-colors"
                      title="Enviar WhatsApp"
                    >
                      {alumno.telefono}
                    </a>
                  </td>

                  <td class="px-6 py-4 text-right">
  <label class="cursor-pointer inline-block">
    <button 
      class="update-status group flex w-fit items-center gap-2 overflow-hidden border rounded-full transition-all active:scale-90 disabled:opacity-50"
      class:list={[
        "p-2 px-4 font-extrabold text-[10px] tracking-widest uppercase",
        alumno.pagado 
          ? "border-emerald-600 text-emerald-600 hover:bg-emerald-600 hover:text-white" 
          : "border-[#982a46] text-[#982a46] hover:bg-[#982a46] hover:text-white"
      ]}
      data-id={alumno.id}
      data-pagado={alumno.pagado.toString()}
    >
      <div class="z-10 transition group-hover:translate-x-2">
        {alumno.pagado ? 'PAGADO' : 'NO PAGADO'}
      </div>
      <svg
        class="size-4 transition duration-500 group-hover:scale-[800%] pointer-events-none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        fill={alumno.pagado ? "currentColor" : "none"}
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"
          stroke-linejoin="round"
          stroke-linecap="round"
        ></path>
      </svg>
    </button>
  </label>
</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const nameSearch = document.getElementById('nameSearch') as HTMLInputElement;
  const careerFilter = document.getElementById('careerFilter') as HTMLSelectElement;

  function performSearch() {
    const rows = document.querySelectorAll('.alumno-row');
    const nameQuery = nameSearch.value.toLowerCase();
    const careerQuery = careerFilter.value.toLowerCase();

    rows.forEach(row => {
      const nombreText = row.querySelector('td:nth-child(2)')?.textContent?.toLowerCase() || '';
      const carreraText = row.querySelector('td:nth-child(3)')?.textContent?.toLowerCase() || '';
      
      const matchesName = nombreText.includes(nameQuery);
      const matchesCareer = careerQuery === "" || carreraText.includes(careerQuery);

      if (matchesName && matchesCareer) {
        (row as HTMLElement).style.display = "";
      } else {
        (row as HTMLElement).style.display = "none";
      }
    });
  }

  nameSearch?.addEventListener('input', performSearch);
  careerFilter?.addEventListener('change', performSearch);

  const buttons = document.querySelectorAll('.update-status');
  buttons.forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const isPaid = btn.getAttribute('data-pagado') === 'true';
      
      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = "Cargando...";

      const { error } = await supabase
        .from('alumnos')
        .update({ pagado: !isPaid })
        .eq('id', id);

      if (error) {
        alert("Error: " + error.message);
        (btn as HTMLButtonElement).disabled = false;
        btn.textContent = isPaid ? 'CANCELAR PAGO' : 'CONFIRMAR PAGO';
      } else {
        window.location.reload();
      }
    });
  });
</script>
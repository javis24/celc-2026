---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Consultamos todos los datos de la base de datos
const { data: alumnos, error } = await supabase
  .from('alumnos')
  .select('*')
  .order('created_at', { ascending: false });

const carreras = [
  "Licenciatura Arquitectura",
  "Licenciatura en Derecho",
  "Licenciatura en Administración de Empresas Turísticas",
  "Contabilidad Pública",
  "Licenciatura en Sistemas Computacionales y Administrativos"
];
---

<Layout title="Admin - CELC 2026">
  <main class="min-h-screen bg-slate-50 p-4 md:p-8">
    <div class="max-w-7xl mx-auto">
      
      <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
          <h1 class="text-4xl font-black text-[#982a46]">Panel de Control</h1>
          <p class="text-slate-500 font-medium">Simposium CELC 2026</p>
        </div>
        
        <div class="flex flex-wrap gap-3">
          <button 
            id="alertPendingBtn"
            class="px-5 py-2.5 bg-amber-600 text-white rounded-full text-sm font-bold hover:bg-amber-700 transition-all shadow-sm flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            Alertar Pendientes
          </button>
          
          <button 
            id="exportExcelBtn"
            class="px-5 py-2.5 bg-emerald-600 text-white rounded-full text-sm font-bold hover:bg-emerald-700 transition-all shadow-sm flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Exportar Excel
          </button>

          <a href="/" class="px-6 py-2.5 bg-white border border-slate-200 rounded-full text-sm font-bold text-slate-600 hover:bg-slate-50 transition-all shadow-sm">
            ← Ir a la Landing
          </a>
        </div>
      </header>

      <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="md:col-span-2 relative">
          <input 
            type="text" 
            id="nameSearch" 
            placeholder="Buscar por nombre del alumno..." 
            class="w-full pl-12 pr-4 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#982a46] outline-none shadow-sm transition-all"
          />
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
        </div>
        
        <select 
          id="careerFilter" 
          class="w-full px-4 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#982a46] outline-none shadow-sm text-slate-600 font-medium"
        >
          <option value="">Todas las Carreras</option>
          {carreras.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>

      <div class="bg-white rounded-[2.5rem] shadow-xl border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left" id="tabla-alumnos">
            <thead>
              <tr class="bg-slate-50/50 border-b border-slate-100">
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest">Estatus</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest">Alumno</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest text-center">Carrera</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest text-center">WhatsApp</th>
                <th class="px-6 py-5 text-xs font-black text-[#982a46] uppercase tracking-widest text-right">Acción</th>
              </tr>
            </thead>
            <tbody id="adminTableBody" class="divide-y divide-slate-50">
              {alumnos?.map((alumno) => (
                <tr class="alumno-row transition-all hover:bg-slate-50" 
                    data-pagado={alumno.pagado ? "SI" : "NO"}
                    data-carrera={alumno.carrera}>
                  <td class="px-6 py-4">
                    <span class={`status-badge inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black ${alumno.pagado ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700'}`}>
                      {alumno.pagado ? 'PAGADO' : 'PENDIENTE'}
                    </span>
                  </td>
                  <td class="px-6 py-4">
                    <div class="font-bold text-slate-800 nombre-txt">{alumno.nombre}</div>
                    <div class="text-xs text-slate-400 email-txt">{alumno.email}</div>
                  </td>
                  <td class="px-6 py-4 text-center">
                    <span class="text-xs font-medium text-slate-500 bg-slate-100 px-2 py-1 rounded-lg carrera-txt">
                      {alumno.carrera}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-center text-sm font-mono font-medium">
                    <a href={`https://wa.me/52${alumno.telefono.replace(/\D/g, '')}`} target="_blank" class="text-green-600 tel-txt">
                      {alumno.telefono}
                    </a>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <button 
                      class="update-status group flex w-fit ml-auto items-center gap-2 overflow-hidden border rounded-full p-2 px-4 font-extrabold text-[10px] tracking-widest uppercase text-white transition-all active:scale-95"
                      style={`background-color: ${alumno.pagado ? '#059669' : '#1e293b'}`}
                      data-id={alumno.id}
                      data-ispaid={alumno.pagado.toString()}
                    >
                      {alumno.pagado ? 'PAGADO' : 'NO PAGADO'}
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="flex justify-between items-center mt-6 px-4">
        <span class="text-sm text-slate-500" id="pagination-info">Cargando datos...</span>
        <div class="flex gap-2">
          <button id="prev-page" class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-bold text-slate-700 hover:bg-slate-50 disabled:opacity-30">
            Anterior
          </button>
          <button id="next-page" class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-bold text-slate-700 hover:bg-slate-50 disabled:opacity-30">
            Siguiente
          </button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js" is:inline></script>

<script>
  import { supabase } from '../lib/supabase';

  let currentPage = 1;
  const itemsPerPage = 10;
  const rows = Array.from(document.querySelectorAll('.alumno-row')) as HTMLElement[];
  let filteredRows = [...rows];

  // --- LÓGICA DE PAGINACIÓN ---
  function updatePagination() {
    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;

    rows.forEach(r => r.style.display = "none");
    
    const visibleRows = filteredRows.slice(start, end);
    visibleRows.forEach(r => r.style.display = "");

    const info = document.getElementById('pagination-info');
    if (info) {
      info.textContent = filteredRows.length === 0 
        ? "Sin resultados" 
        : `Mostrando ${start + 1}-${Math.min(end, filteredRows.length)} de ${filteredRows.length}`;
    }

    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = end >= filteredRows.length;
  }

  // --- BUSCADOR Y FILTROS ---
  const nameInput = document.getElementById('nameSearch') as HTMLInputElement;
  const careerSelect = document.getElementById('careerFilter') as HTMLSelectElement;

  function performSearch() {
    const nQ = nameInput.value.toLowerCase();
    const cQ = careerSelect.value.toLowerCase();

    filteredRows = rows.filter(row => {
      const nombre = row.querySelector('.nombre-txt')?.textContent?.toLowerCase() || '';
      const carrera = row.querySelector('.carrera-txt')?.textContent?.toLowerCase() || '';
      return nombre.includes(nQ) && (cQ === "" || carrera.includes(cQ));
    });

    currentPage = 1;
    updatePagination();
  }

  nameInput?.addEventListener('input', performSearch);
  careerSelect?.addEventListener('change', performSearch);
  document.getElementById('prev-page')?.addEventListener('click', () => { currentPage--; updatePagination(); });
  document.getElementById('next-page')?.addEventListener('click', () => { currentPage++; updatePagination(); });

  // --- EXPORTAR A EXCEL (.xlsx) ---
  document.getElementById('exportExcelBtn')?.addEventListener('click', () => {
    // @ts-ignore
    const XLSX = window.XLSX;
    
    // Preparar datos puros para el Excel (toda la lista cargada)
    const dataToExport = rows.map(row => ({
      Estatus: row.querySelector('.status-badge')?.textContent?.trim(),
      Nombre: row.querySelector('.nombre-txt')?.textContent?.trim(),
      Email: row.querySelector('.email-txt')?.textContent?.trim(),
      Carrera: row.querySelector('.carrera-txt')?.textContent?.trim(),
      Telefono: row.querySelector('.tel-txt')?.textContent?.trim()
    }));

    const worksheet = XLSX.utils.json_to_sheet(dataToExport);
    const workbook = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(workbook, worksheet, "Lista Alumnos");
    
    // Descarga el archivo
    XLSX.writeFile(workbook, "Alumnos_CELC_2026.xlsx");
  });

  // --- ACTUALIZAR ESTATUS (SUPABASE) ---
  document.querySelectorAll('.update-status').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const isPaid = btn.getAttribute('data-ispaid') === 'true';
      
      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = "Cargando...";

      const { error } = await supabase
        .from('alumnos')
        .update({ pagado: !isPaid })
        .eq('id', id);

      if (error) {
        alert("Error: " + error.message);
        location.reload();
      } else {
        location.reload();
      }
    });
  });

  // Inicializar
  updatePagination();
</script>